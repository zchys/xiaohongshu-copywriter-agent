# 小红书 Cookie（从浏览器 F12 复制）
XHS_COOKIE=your_cookie_here

# ═══════════════════════════════════════════════════
# AI 提供商配置
# ═══════════════════════════════════════════════════
# 选择一个提供商: openai | anthropic | deepseek | minimax | mimo
AI_PROVIDER=openai

# AI 模型（不填则使用提供商默认模型）
# AI_MODEL=gpt-4o

# ═══════════════════════════════════════════════════
# API Keys（填你使用的那个提供商的 Key）
# ═══════════════════════════════════════════════════

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key

# MiniMax
MINIMAX_API_KEY=your-minimax-key

# Xiaomi MiMo
MIMO_API_KEY=your-mimo-key

# ═══════════════════════════════════════════════════
# 其他配置
# ═══════════════════════════════════════════════════

# 数据库路径
DB_PATH=./data/xhs.db

# 日志级别
LOG_LEVEL=info

# 采集配置
CRAWL_INTERVAL_MIN=3000
CRAWL_INTERVAL_MAX=8000
CRAWL_BATCH_SIZE=30
CRAWL_DAILY_LIMIT=300
